{
  "worktree": {
    "setup": [
      "bun install",
      "bunx skills experimental_install"
    ],
    "teardown": "bun run dev:stop && rm -f apps/server/solar.db apps/server/solar.db-shm apps/server/solar.db-wal"
  },
  "scripts": {
    "web": {
      "type": "service",
      "command": "bun run dev:foreground",
      "port": 3000
    },
    "typecheck": { "command": "bun run typecheck" },
    "build": { "command": "bun run build" },
    "migrate": { "command": "bun run migrate" },
    "migrate:auth": { "command": "bun run migrate:auth" },
    "codegen": { "command": "bun run codegen" }
  }
}
