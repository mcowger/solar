# Generate a production secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-random-secret

# Google OAuth credentials. Redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: comma-separated email domains allowed for Google sign-in
# (e.g. example.com,corp.example.com). Empty allows any domain.
GOOGLE_ALLOWED_DOMAINS=

# Optional: trace, debug, info, warn, or error
SOLAR_LOG_LEVEL=info
